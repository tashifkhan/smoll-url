# Server
listen_address=0.0.0.0
port=4567

# Storage
# You can use db_url, database, or db_path
# Example for local run:
# db_url=urls.sqlite
# Example for docker:
# db_url=/data/urls.db
db_url=urls.sqlite

# Auth (change these)
password=changeme
api_key=changeme

# Core behavior
slug_length=6
slug_style=Pair
allow_capital_letters=false
try_longer_slug=false
use_wal_mode=true
ensure_acid=true
use_temp_redirect=false

# Optional
site_url=
public_mode=false
public_mode_expiry_delay=0
disable_frontend=false
cache_control_header=
custom_landing_directory=
frontend_page_size=10
hash_algorithm=
